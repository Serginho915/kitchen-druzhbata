# Copy this file to .env and fill in the values
# .env is read by the Next.js frontend (envDir set to project root in next.config.ts)
# For production, the docker-compose.prod.yml overrides these via environment: section

# Backend API base URL
# Local dev:  http://localhost:8000/api
# Production: https://sofiafood.bg/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
